# Copy to .env (or set as system env vars / NSSM AppEnvironmentExtra on Windows)
WEBMANAGER_ROOT=D:\webmanager
PORT=8088

# CHANGE THESE before production
JWT_SECRET=please-change-this-to-a-long-random-string
ADMIN_USER=admin
ADMIN_PASS=admin1234

# nginx (Windows). Defaults to <ROOT>\nginx\nginx.exe
# NGINX_EXE=D:\webmanager\nginx\nginx.exe
# NGINX_PREFIX=D:\webmanager\nginx

# git (must be on PATH, or set absolute path)
# GIT_EXE=git
